<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plano de Medicação - Dona Maria</title>
    <style>
        /* 1. RESET E DEFINIÇÕES BASE */
        :root {
            --morning: #FFF9C4;
            --noon: #E3F2FD;
            --night: #F3E5F5;
            --text-main: #000000;
            --accent: #D32F2F;
        }

        @page { size: A4; margin: 0; }

        body {
            margin: 0;
            padding: 0;
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f0f0f0;
            color: var(--text-main);
            display: flex;
            justify-content: center;
        }

        /* 2. CONTAINER A4 / RESPONSIVO */
        .page {
            width: 210mm;
            min-height: 297mm;
            background: white;
            padding: 10mm;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            border: 4px solid #000;
        }

        /* Ajuste para ecrãs digitais (Telemóveis/Tablets) */
        @media screen and (max-width: 210mm) {
            .page { width: 100vw; border: none; padding: 10px; }
        }

        /* 3. CABEÇALHO */
        .header {
            text-align: center;
            border-bottom: 4px solid #000;
            margin-bottom: 20px;
            padding-bottom: 10px;
        }
        .header h1 { font-size: 45pt; margin: 0; text-transform: uppercase; }
        .header p { font-size: 18pt; margin: 5px 0; font-weight: bold; }

        /* 4. BLOCOS DE PERÍODO */
        .card {
            margin-bottom: 15px;
            border: 3px solid #000;
            border-radius: 15px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .card-header {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
            gap: 20px;
            border-bottom: 2px solid rgba(0,0,0,0.1);
        }
        .icon-large { font-size: 60pt; line-height: 1; }
        .title-group { text-align: center; }
        .title-group h2 { font-size: 28pt; margin: 0; text-transform: uppercase; }
        .title-group span { font-size: 18pt; font-weight: bold; opacity: 0.8; }

        /* 5. GRELHA DE MEDICAMENTOS (O SEGREDO DA ADAPTAÇÃO) */
        .med-row {
            display: grid;
            /* Se houver espaço, faz 4 colunas iguais. Se não, quebra. */
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 10px;
            padding: 15px;
            align-items: center;
            text-align: center;
            border-bottom: 1px solid rgba(0,0,0,0.1);
        }
        .med-row:last-child { border-bottom: none; }

        /* Estilos de Texto */
        .med-name { font-size: 26pt; font-weight: 900; line-height: 1.1; }
        .med-mg { font-size: 14pt; font-weight: bold; color: #444; display: block; }
        .med-qty { font-size: 24pt; font-weight: 900; color: var(--accent); }
        .med-dialect { 
            font-size: 14pt; 
            font-weight: bold; 
            background: rgba(0,0,0,0.05); 
            padding: 5px; 
            border-radius: 5px;
            display: inline-block;
        }

        /* Cores de Fundo */
        .morning { background-color: var(--morning); }
        .noon { background-color: var(--noon); border-style: dashed; }
        .night { background-color: var(--night); }

        /* 6. RODAPÉ */
        .footer {
            margin-top: auto;
            background: #000;
            color: #fff;
            text-align: center;
            padding: 15px;
            font-size: 18pt;
            font-weight: bold;
            border-radius: 10px;
        }

        /* AJUSTES ESPECÍFICOS PARA MOBILE PORTRAIT */
        @media screen and (max-width: 600px) {
            .med-name { font-size: 20pt; }
            .med-qty { font-size: 18pt; }
            .icon-large { font-size: 40pt; }
            .header h1 { font-size: 30pt; }
        }
    </style>
</head>
